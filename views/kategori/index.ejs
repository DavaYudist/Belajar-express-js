<!-- Standar HTML5 -->
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- Menampilkan variabel title EJS -->
    <title><%= title %></title>
    <!-- UI framework dan CSS kustom -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body { background-color: #f8f9fa; }
        .card { border-radius: 15px; }
    </style>
</head>
<!-- Memusatkan konten -->
<body class="container mt-5">
    <div class="row">
        <div class="col-md-12">
            <!-- Wrapper UI modern dengan bayangan -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white p-3">
                    <h3 class="card-title mb-0"><%= title %></h3>
                </div>
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="text-secondary">Daftar Data</h5>
                        <!-- Link navigasi -->
                        <a href="/kategori/create" class="btn btn-success shadow-sm">+ Tambah Kategori</a>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-hover table-striped border">
                            <thead class="table-dark">
                                <tr>
                                    <th width="10%">No</th>
                                    <th>Nama Kategori</th>
                                    <th width="20%" class="text-center">Aksi</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Memeriksa data dari database -->
                                <% if(kategori.length > 0) { %>
                                    <!-- Melakukan iterasi baris data -->
                                    <% for(var i = 0; i < kategori.length; i++) { %>
                                        <tr>
                                            <!-- Penomoran dinamis -->
                                            <td><%= i + 1 %></td>
                                            <!-- Mengambil kolom database -->
                                            <td><%= kategori[i].nama_kategori %></td>
                                            <td class="text-center">
                                                <a href="#" class="btn btn-sm btn-warning text-white">Edit</a>
                                                <a href="#" class="btn btn-sm btn-danger">Hapus</a>
                                            </td>
                                        </tr>
                                    <% } %>
                                <!-- untuk menangani database kosong -->
                                <% } else { %>
                                    <tr>
                                        <td colspan="3" class="text-center text-muted p-4">
                                            <!-- Umpan balik visual untuk data kosong -->
                                            <div class="alert alert-info mb-0">
                                                Data kategori masih kosong.
                                            </div>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <p class="text-center text-muted mt-4"><small>&copy; 2026 - PENS Sumenep</small></p>
        </div>
    </div>
</body>
</html>