<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<div class="container mt-4 mb-5">
    <%- include('../partials/massage') %>
    
    <div class="card shadow-sm border-0">
        <div class="card-header bg-success text-white p-3">
            <h3 class="card-title mb-0"><%= title %></h3>
        </div>
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="text-secondary">Data Mahasiswa</h5>
                <a href="/mahasiswa/create" class="btn btn-success shadow-sm">+ Tambah Mahasiswa</a>
            </div>

            <div class="table-responsive">
                <table class="table table-hover table-striped border align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th width="5%">No</th>
                            <th>Foto</th>
                            <th>NRP</th>
                            <th>Nama</th>
                            <th>Jenis Kelamin</th>
                            <th width="20%" class="text-center">Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (mahasiswa.length > 0) { %>
                            <% mahasiswa.forEach((item, index) => { %>
                                <tr>
                                    <td><%= index + 1 %></td>
                                    <td>
                                        <% if (item.foto_mahasiswa) { %>
                                            <img src="/images/mahasiswa/<%= item.foto_mahasiswa %>" alt="<%= item.nama %>" style="max-width: 50px; border-radius: 5px; cursor: pointer;" data-bs-toggle="modal" data-bs-target="#imageModal" data-bs-image="/images/mahasiswa/<%= item.foto_mahasiswa %>">
                                        <% } else { %>
                                            <span class="text-muted">No Image</span>
                                        <% } %>
                                    </td>
                                    <td class="fw-bold"><%= item.nrp %></td>
                                    <td><%= item.nama %></td>
                                    <td><%= item.jenis_kelamin %></td>
                                    <td class="text-center">
                                        <a href="/mahasiswa/edit/<%= item.id_mahasiswa %>" class="btn btn-sm btn-warning text-white">
                                            Edit
                                        </a>
                                        <a href="/mahasiswa/delete/<%= item.id_mahasiswa %>" class="btn btn-sm btn-danger" 
                                           onclick="return confirm('Hapus mahasiswa <%= item.nama %>?');">
                                            Hapus
                                        </a>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" class="text-center text-muted p-4">Belum ada data mahasiswa tersedia.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    
    <div class="modal fade" id="imageModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 bg-transparent">
                <div class="modal-body p-0 text-center">
                    <img id="modalImage" class="img-fluid w-100" src="" alt="Preview">
                </div>
            </div>
        </div>
    </div>
</div>
<%- include('../partials/foot') %>
